{% extends 'base.html.twig' %}

{% block title %}{{ movie.Title }}{% endblock %}

{% block stylesheets %}
<style>
    .show-wrapper {
        padding-top: 80px;
        min-height: 100vh;
        background: #0d0d0d;
    }

    .movie-hero {
        background: linear-gradient(135deg, #1a0000, #0d0d0d);
        border-bottom: 2px solid #e50914;
        padding: 4rem 2rem 3rem;
        text-align: center;
    }

    .movie-hero h1 {
        font-size: 2.8rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 1rem;
    }

    .movie-meta {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .movie-meta span {
        color: #aaa;
        font-size: 0.95rem;
    }

    .movie-meta a {
        color: #f39c12;
        text-decoration: none;
    }

    .avg-score-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(229, 9, 20, 0.15);
        border: 1px solid rgba(229, 9, 20, 0.4);
        padding: 0.5rem 1.2rem;
        border-radius: 20px;
        color: #fff;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .show-content {
        max-width: 860px;
        margin: 0 auto;
        padding: 3rem 2rem;
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #e50914;
        display: inline-block;
    }

    .resume-block {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 1.5rem 2rem;
        color: #ccc;
        line-height: 1.8;
        margin-bottom: 3rem;
    }

    .rating-cta {
        text-align: center;
        margin-bottom: 3rem;
    }

    .rating-cta a {
        display: inline-block;
        padding: 0.9rem 2.5rem;
        border-radius: 30px;
        background: #e50914;
        color: #fff;
        font-weight: 700;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.3s;
        box-shadow: 0 8px 25px rgba(229, 9, 20, 0.3);
    }

    .rating-cta a:hover {
        background: #b20710;
        transform: translateY(-2px);
    }

    .reviews-section {
        margin-bottom: 3rem;
    }

    .review-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        padding: 1.2rem 1.5rem;
        margin-bottom: 1rem;
        transition: border-color 0.3s;
    }

    .review-card:hover {
        border-color: rgba(229, 9, 20, 0.3);
    }

    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.6rem;
    }

    .reviewer-name {
        font-weight: 700;
        color: #fff;
        font-size: 0.95rem;
        margin-bottom: 0.3rem;
    }

    .review-stars {
        font-size: 1rem;
        letter-spacing: 1px;
        color: #f39c12;
    }

    .review-score {
        color: #666;
        font-size: 0.8rem;
        margin-left: 0.3rem;
    }

    .review-comment {
        color: #aaa;
        font-size: 0.9rem;
        line-height: 1.6;
        margin-top: 0.8rem;
        margin-bottom: 0;
    }

    .btn-delete-review {
        background: transparent;
        border: 1px solid rgba(229, 9, 20, 0.4);
        color: #e50914;
        padding: 0.3rem 0.7rem;
        border-radius: 8px;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
    }

    .btn-delete-review:hover {
        background: #e50914;
        color: #fff;
    }

    .no-reviews {
        text-align: center;
        padding: 2.5rem;
        color: #555;
        background: rgba(255,255,255,0.02);
        border-radius: 12px;
        border: 1px dashed rgba(255,255,255,0.08);
        font-size: 0.95rem;
    }

    .action-bar {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        padding-top: 2rem;
        border-top: 1px solid rgba(255,255,255,0.08);
    }

    .btn-back {
        padding: 0.7rem 1.5rem;
        border-radius: 25px;
        border: 1px solid rgba(255,255,255,0.2);
        background: transparent;
        color: #ccc;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.3s;
    }

    .btn-back:hover {
        border-color: #fff;
        color: #fff;
    }

    .btn-edit-movie {
        padding: 0.7rem 1.5rem;
        border-radius: 25px;
        background: #f39c12;
        color: #fff;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        border: none;
        transition: opacity 0.2s;
    }

    .btn-edit-movie:hover {
        opacity: 0.85;
        color: #fff;
    }

    .btn-delete-movie {
        padding: 0.7rem 1.5rem;
        border-radius: 25px;
        background: #e50914;
        color: #fff;
        font-weight: 600;
        font-size: 0.9rem;
        border: none;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    .btn-delete-movie:hover {
        opacity: 0.85;
    }
</style>
{% endblock %}

{% block body %}
<div class="show-wrapper">

    {# Hero #}
    <div class="movie-hero">
        <h1>{{ movie.Title }}</h1>
        <div class="movie-meta">
            <span>📅 {{ movie.Date ? movie.Date|date('d/m/Y') : 'Date inconnue' }}</span>
            <span>⏱ {{ movie.Time ? movie.Time|date('H:i') : '--:--' }}</span>
            <span>
                <a href="https://www.imdb.com/title/tt{{ '%07d'|format(movie.imdbId) }}" target="_blank">
                    🎬 Voir sur IMDB
                </a>
            </span>
        </div>
        {% if avgScore %}
            <div class="avg-score-badge">
                ⭐ {{ avgScore|number_format(1) }}/5
                <span style="color: #aaa; font-weight: 400; font-size: 0.85rem;">
                    — {{ ratings|length }} avis
                </span>
            </div>
        {% else %}
            <div class="avg-score-badge">⭐ Aucune note pour l'instant</div>
        {% endif %}
    </div>

    <div class="show-content">

        {# Résumé #}
        <p class="section-title">📖 Résumé</p>
        <div class="resume-block">
            {{ movie.Resume ?? 'Aucun résumé disponible.' }}
        </div>

        {# Bouton avis #}
        {% if is_granted('ROLE_USER') %}
            <div class="rating-cta">
                <a href="{{ path('app_rating_add', {'id': movie.id}) }}">✍️ Laisser un avis</a>
            </div>
        {% endif %}

        {# Avis #}
        <div class="reviews-section">
            <p class="section-title">
                💬 Avis{% if ratings is not empty %} ({{ ratings|length }}){% endif %}
            </p>

            {% if ratings is empty %}
                <div class="no-reviews">
                    Aucun avis pour ce film. Soyez le premier à noter !
                </div>
            {% else %}
                {% for rating in ratings %}
                    <div class="review-card">
                        <div class="review-header">
                            <div>
                                <div class="reviewer-name">
                                    {{ rating.movieLover.firstname }} {{ rating.movieLover.lastname }}
                                </div>
                                <div class="review-stars">
                                    {% for i in 1..5 %}
                                        {% if i <= rating.score %}⭐{% else %}☆{% endif %}
                                    {% endfor %}
                                    <span class="review-score">{{ rating.score }}/5</span>
                                </div>
                            </div>
                            {% if rating.movieLover == app.user or is_granted('ROLE_ADMIN') %}
                                <form method="post" action="{{ path('app_rating_delete', {'id': rating.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ rating.id) }}">
                                    <button type="submit" class="btn-delete-review">🗑 Supprimer</button>
                                </form>
                            {% endif %}
                        </div>
                        {% if rating.comment %}
                            <p class="review-comment">{{ rating.comment }}</p>
                        {% endif %}
                    </div>
                {% endfor %}
            {% endif %}
        </div>

        {# Actions #}
        <div class="action-bar">
            <a href="{{ path('app_movies_index') }}" class="btn-back">← Retour à la liste</a>
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_movies_edit', {'id': movie.id}) }}" class="btn-edit-movie">✏️ Modifier</a>
                <form method="post" action="{{ path('app_movies_delete', {'id': movie.id}) }}"
                      onsubmit="return confirm('Supprimer ce film ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ movie.id) }}">
                    <button type="submit" class="btn-delete-movie">🗑 Supprimer</button>
                </form>
            {% endif %}
        </div>

    </div>
</div>
{% endblock %}
