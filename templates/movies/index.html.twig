{% extends 'base.html.twig' %}

{% block title %}Films - SymfonySandBox{% endblock %}

{% block body %}
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: 'Segoe UI', sans-serif;
        background: #0d0d0d;
        color: #fff;
        min-height: 100vh;
    }

    /* HERO */
    .hero {
        min-height: 60vh;
        background: 
            linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.8) 60%, #0d0d0d 100%),
            url('https://image.tmdb.org/t/p/original/628Dep6AxEtDxjZoGP78TsOxYbK.jpg') center/cover no-repeat;
        display: flex;
        align-items: center;
        padding: 0 3rem;
    }

    .hero-content {
        max-width: 600px;
        margin-top: 80px;
    }

    .hero-badge {
        display: inline-block;
        background: #e50914;
        color: #fff;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 0.3rem 0.8rem;
        border-radius: 4px;
        margin-bottom: 1.2rem;
    }

    .hero h1 {
        font-size: 3.5rem;
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1rem;
    }

    .hero h1 span { color: #e50914; }

    .hero p {
        font-size: 1.1rem;
        color: #aaa;
        margin-bottom: 2rem;
        line-height: 1.6;
    }

    /* GRID */
    .movies-section {
        padding: 5rem 3rem;
        max-width: 1400px;
        margin: 0 auto;
    }

    .movies-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
    }

    .movie-card {
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        overflow: hidden;
        transition: transform 0.3s, border-color 0.3s;
        display: flex;
        flex-direction: column;
    }

    .movie-card:hover {
        transform: translateY(-8px);
        border-color: #e50914;
        box-shadow: 0 20px 40px rgba(229, 9, 20, 0.2);
    }

    .movie-poster-container {
        height: 380px;
        overflow: hidden;
    }

    .movie-poster {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .movie-card:hover .movie-poster {
        transform: scale(1.05);
    }

    .movie-no-poster {
        height: 100%;
        background: #1a1a1a;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        color: #666;
    }

    .movie-content {
        padding: 1.8rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .movie-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 0.6rem;
        line-height: 1.3;
    }

    .movie-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
        color: #aaa;
        font-size: 0.9rem;
    }

    .movie-rating {
        background: #e50914;
        color: #fff;
        padding: 0.25rem 0.7rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .movie-overview {
        color: #bbb;
        font-size: 0.9rem;
        line-height: 1.6;
        flex-grow: 1;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }

    .movie-actions { margin-top: auto; }

    .btn-primary {
        display: block;
        background: #e50914;
        color: #fff;
        padding: 0.8rem 1.5rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        text-align: center;
        transition: background 0.3s;
    }

    .btn-primary:hover { background: #c40812; }

    .no-movies {
        grid-column: 1 / -1;
        text-align: center;
        padding: 6rem 2rem;
        color: #666;
    }

    .no-movies h2 {
        font-size: 2rem;
        margin-bottom: 1rem;
        color: #ccc;
    }

    @media (max-width: 768px) {
        .hero { padding: 0 1.5rem; min-height: 50vh; }
        .hero h1 { font-size: 2.5rem; }
        .movies-section { padding: 3rem 1.5rem; }
        .movies-grid { grid-template-columns: 1fr; }
    }
</style>

<!-- HERO -->
<section class="hero">
    <div class="hero-content">
        <span class="hero-badge">🎬 Catalogue complet</span>
        <h1>Tous les <span>Films</span></h1>
        <p>Explorez notre catalogue alimenté en temps réel par l'API The Movie Database.</p>
    </div>
</section>

<!-- GRID -->
<section class="movies-section">
    <div class="movies-grid">
        {% for movie in movies %}
            <div class="movie-card">
                <div class="movie-poster-container">
                    {% if movie.poster_path %}
                        <img src="https://image.tmdb.org/t/p/w500{{ movie.poster_path }}"
                             alt="{{ movie.title }}"
                             class="movie-poster"
                             loading="lazy">
                    {% else %}
                        <div class="movie-no-poster">🎥</div>
                    {% endif %}
                </div>

                <div class="movie-content">
                    <h3 class="movie-title">{{ movie.title }}</h3>

                    <div class="movie-meta">
                        <span>{{ movie.release_date ?: 'À venir' }}</span>
                        <span class="movie-rating">
                            {{ movie.vote_average ? movie.vote_average|number_format(1) : '?' }}/10
                        </span>
                    </div>

                    <p class="movie-overview">{{ movie.overview }}</p>

                    <div class="movie-actions">
                        <a href="{{ path('app_movies_show', {'id': movie.id}) }}" class="btn-primary">
                            Voir détails →
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="no-movies">
                <div style="font-size: 5rem; margin-bottom: 1.5rem;">🎬</div>
                <h2>Aucun film disponible</h2>
                <p>Revenez bientôt pour découvrir notre sélection !</p>
            </div>
        {% endfor %}
    </div>
</section>

{% endblock %}
