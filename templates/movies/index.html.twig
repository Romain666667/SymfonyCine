{% extends 'base.html.twig' %}

{% block title %}Films{% endblock %}

{% block stylesheets %}
<style>
    .page-wrapper {
        padding-top: 100px;
        min-height: 100vh;
        background: #0d0d0d;
    }

    .page-header {
        text-align: center;
        padding: 3rem 1rem 2rem;
    }

    .page-header h1 {
        font-size: 2.5rem;
        font-weight: 800;
        color: #fff;
        letter-spacing: 1px;
    }

    .page-header h1 span {
        color: #e50914;
    }

    .search-bar {
        max-width: 600px;
        margin: 0 auto 3rem;
        padding: 0 1rem;
        display: flex;
        gap: 0.5rem;
    }

    .search-bar input {
        flex: 1;
        padding: 0.8rem 1.2rem;
        border-radius: 25px;
        border: 1px solid rgba(255,255,255,0.15);
        background: rgba(255,255,255,0.05);
        color: #fff;
        font-size: 0.95rem;
        outline: none;
        transition: border 0.3s;
    }

    .search-bar input:focus {
        border-color: #e50914;
    }

    .search-bar input::placeholder {
        color: #888;
    }

    .search-bar button {
        padding: 0.8rem 1.5rem;
        border-radius: 25px;
        border: none;
        background: #e50914;
        color: #fff;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.3s;
    }

    .search-bar button:hover {
        background: #b20710;
    }

    .search-bar .reset-btn {
        padding: 0.8rem 1.2rem;
        border-radius: 25px;
        border: 1px solid rgba(255,255,255,0.2);
        background: transparent;
        color: #ccc;
        cursor: pointer;
        text-decoration: none;
        display: flex;
        align-items: center;
        transition: all 0.3s;
    }

    .search-bar .reset-btn:hover {
        border-color: #e50914;
        color: #fff;
    }

    .results-info {
        text-align: center;
        color: #888;
        margin-bottom: 2rem;
        font-size: 0.9rem;
    }

    .results-info strong {
        color: #fff;
    }

    .movies-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1.5rem;
        padding: 0 3rem 4rem;
        max-width: 1400px;
        margin: 0 auto;
    }

    .movie-card {
        border-radius: 12px;
        overflow: hidden;
        background: #1a1a1a;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
        position: relative;
    }

    .movie-card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 20px 40px rgba(229, 9, 20, 0.3);
    }

    .movie-card img {
        width: 100%;
        aspect-ratio: 2/3;
        object-fit: cover;
        display: block;
    }

    .movie-card .no-poster {
        width: 100%;
        aspect-ratio: 2/3;
        background: linear-gradient(135deg, #1a1a2e, #16213e);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #555;
        font-size: 3rem;
    }

    .movie-card .no-poster span {
        font-size: 0.8rem;
        margin-top: 0.5rem;
        color: #444;
    }

    .movie-card-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(transparent, rgba(0,0,0,0.95));
        padding: 2rem 1rem 1rem;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .movie-card:hover .movie-card-overlay {
        opacity: 1;
    }

    .movie-card-overlay h5 {
        font-size: 0.95rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 0.3rem;
    }

    .movie-card-overlay p {
        font-size: 0.75rem;
        color: #aaa;
        margin-bottom: 0.8rem;
    }

    .movie-card-overlay a.btn-voir {
        display: block;
        text-align: center;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        background: #e50914;
        color: #fff;
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 600;
        transition: background 0.3s;
    }

    .movie-card-overlay a.btn-voir:hover {
        background: #b20710;
    }

    .movie-title-below {
        padding: 0.8rem;
    }

    .movie-title-below h5 {
        font-size: 0.9rem;
        font-weight: 600;
        color: #fff;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .movie-title-below p {
        font-size: 0.75rem;
        color: #888;
        margin-top: 0.2rem;
    }

    .admin-actions {
        display: flex;
        gap: 0.5rem;
        padding: 0 0.8rem 0.8rem;
    }

    .admin-actions a, .admin-actions button {
        flex: 1;
        padding: 0.4rem;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 600;
        text-align: center;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: opacity 0.2s;
    }

    .admin-actions a:hover, .admin-actions button:hover {
        opacity: 0.8;
    }

    .btn-edit {
        background: #f39c12;
        color: #fff;
    }

    .btn-delete {
        background: #e50914;
        color: #fff;
    }

    .empty-state {
        text-align: center;
        padding: 5rem 1rem;
        color: #555;
    }

    .empty-state p {
        font-size: 1.3rem;
        margin-bottom: 1rem;
    }

    .add-btn {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        background: #e50914;
        color: #fff;
        padding: 1rem 1.5rem;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.95rem;
        box-shadow: 0 8px 25px rgba(229, 9, 20, 0.4);
        transition: all 0.3s;
        z-index: 50;
    }

    .add-btn:hover {
        background: #b20710;
        transform: translateY(-3px);
        color: #fff;
    }
</style>
{% endblock %}

{% block body %}
<div class="page-wrapper">

    <div class="page-header">
        <h1>Notre <span>Catalogue</span></h1>
    </div>

    <form method="get" action="{{ path('app_movies_index') }}" class="search-bar">
        <input type="text" name="search" placeholder="Rechercher un film..." value="{{ searchTerm }}">
        <button type="submit">🔍 Rechercher</button>
        {% if searchTerm %}
            <a href="{{ path('app_movies_index') }}" class="reset-btn">✕</a>
        {% endif %}
    </form>

    {% if searchTerm %}
        <p class="results-info">
            Résultats pour <strong>"{{ searchTerm }}"</strong>
            — {{ movies|length }} film{{ movies|length > 1 ? 's' : '' }}
        </p>
    {% endif %}

    {% if movies is empty %}
        <div class="empty-state">
            <p>😕 Aucun film trouvé</p>
            {% if searchTerm %}
                <a href="{{ path('app_movies_index') }}" style="color: #e50914;">Voir tous les films</a>
            {% endif %}
        </div>
    {% else %}
        <div class="movies-grid">
            {% for movie in movies %}
                <div class="movie-card">
                        <div class="no-poster">
                            🎥
                            <span>Pas d'affiche</span>
                        </div>

                    <div class="movie-card-overlay">
                        <h5>{{ movie.Title }}</h5>
                        <p>📅 {{ movie.Date ? movie.Date|date('Y') : '—' }}</p>
                        <a href="{{ path('app_movies_show', {'id': movie.id}) }}" class="btn-voir">Voir le film →</a>
                    </div>

                    <div class="movie-title-below">
                        <h5>{{ movie.Title }}</h5>
                        <p>{{ movie.Date ? movie.Date|date('Y') : 'Année inconnue' }}</p>
                    </div>

                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="admin-actions">
                            <a href="{{ path('app_movies_edit', {'id': movie.id}) }}" class="btn-edit">✏️ Modifier</a>
                            <form method="post" action="{{ path('app_movies_delete', {'id': movie.id}) }}"
                                  onsubmit="return confirm('Supprimer {{ movie.Title }} ?')" style="flex:1; display:flex;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ movie.id) }}">
                                <button type="submit" class="btn-delete" style="flex:1;">🗑 Supprimer</button>
                            </form>
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}

    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_movies_new') }}" class="add-btn">+ Ajouter un film</a>
    {% endif %}

</div>
{% endblock %}
