{% extends 'base.html.twig' %}

{% block title %}Accueil - SymfonySandBox{% endblock %}

{% block body %}
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: 'Segoe UI', sans-serif;
        background: #0d0d0d;
        color: #fff;
        min-height: 100vh;
    }

    /* NAVBAR */
    nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.2rem 3rem;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(10px);
        position: fixed;
        width: 100%;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .nav-logo {
        font-size: 1.5rem;
        font-weight: 700;
        color: #e50914;
        letter-spacing: 2px;
        text-decoration: none;
    }

    .nav-links {
        display: flex;
        gap: 1rem;
    }

    .nav-links a {
        color: #ccc;
        text-decoration: none;
        padding: 0.5rem 1.2rem;
        border-radius: 25px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        border: 1px solid transparent;
    }

    .nav-links a:hover,
    .nav-links a.active {
        color: #fff;
        border-color: #e50914;
        background: rgba(229, 9, 20, 0.15);
    }

    /* HERO */
    .hero {
        min-height: 100vh;
        background: 
            linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.8) 60%, #0d0d0d 100%),
            url('https://image.tmdb.org/t/p/original/628Dep6AxEtDxjZoGP78TsOxYbK.jpg') center/cover no-repeat;
        display: flex;
        align-items: center;
        padding: 0 3rem;
    }

    .hero-content {
        max-width: 600px;
        margin-top: 80px;
    }

    .hero-badge {
        display: inline-block;
        background: #e50914;
        color: #fff;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 0.3rem 0.8rem;
        border-radius: 4px;
        margin-bottom: 1.2rem;
    }

    .hero h1 {
        font-size: 3.5rem;
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 1rem;
    }

    .hero h1 span {
        color: #e50914;
    }

    .hero p {
        font-size: 1.1rem;
        color: #aaa;
        margin-bottom: 2rem;
        line-height: 1.6;
    }

    .hero-buttons {
        display: flex;
        gap: 1rem;
    }

    .btn-primary {
        background: #e50914;
        color: #fff;
        padding: 0.9rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 1rem;
        transition: background 0.3s;
    }

    .btn-primary:hover { background: #c40812; }

    .btn-secondary {
        background: rgba(255,255,255,0.1);
        color: #fff;
        padding: 0.9rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 1rem;
        border: 1px solid rgba(255,255,255,0.3);
        transition: background 0.3s;
    }

    .btn-secondary:hover { background: rgba(255,255,255,0.2); }

    /* FEATURES */
    .features {
        padding: 5rem 3rem;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .feature-card {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
        transition: transform 0.3s, border-color 0.3s;
    }

    .feature-card:hover {
        transform: translateY(-5px);
        border-color: #e50914;
    }

    .feature-icon {
        font-size: 2.5rem;
        margin-bottom: 1rem;
    }

    .feature-card h3 {
        font-size: 1.2rem;
        margin-bottom: 0.5rem;
    }

    .feature-card p {
        color: #888;
        font-size: 0.9rem;
        line-height: 1.5;
    }
</style>    

<!-- HERO -->
<section class="hero">
    <div class="hero-content">
        <span class="hero-badge">🔥 Tendances du moment</span>
        <h1>Découvrez les meilleurs <span>Films</span></h1>
        <p>Explorez des milliers de films, trouvez vos favoris et restez à jour avec les dernières sorties grâce à l'API TMDB.</p>
        <div class="hero-buttons">
            <a href="{{ path('app_movies_index') }}" class="btn-primary">Voir les films</a>
            <a href="#" class="btn-secondary">En savoir plus</a>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="features">
    <div class="feature-card">
        <div class="feature-icon">🎥</div>
        <h3>Catalogue complet</h3>
        <p>Accédez à des milliers de films grâce à l'API The Movie Database.</p>
    </div>
    <div class="feature-card">
        <div class="feature-icon">⭐</div>
        <h3>Notes & Avis</h3>
        <p>Consultez les notes et avis de la communauté pour chaque film.</p>
    </div>
    <div class="feature-card">
        <div class="feature-icon">🔍</div>
        <h3>Recherche avancée</h3>
        <p>Trouvez n'importe quel film en quelques secondes avec la recherche TMDB.</p>
    </div>
</section>

{% endblock %}
